{
  "name": "marketing-hub",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build --webpack",
    "start": "next start --hostname 127.0.0.1",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:init": "node --import tsx scripts/db-init.ts",
    "db:migrate": "node --import tsx scripts/db-init.ts",
    "db:seed:demo": "node --import tsx scripts/seed-demo.ts",
    "data:reset": "node --import tsx scripts/reset-data.ts",
    "benchmark:leads": "node --env-file=.env.local --import tsx scripts/live-lead-benchmark.ts",
    "benchmark:leads:revalidate": "node --import tsx scripts/revalidate-lead-benchmark.ts",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@tailwindcss/postcss": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "openai": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "latest",
    "rehype-sanitize": "latest",
    "remark-gfm": "latest",
    "sharp": "latest",
    "tailwindcss": "latest",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "jsdom": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "postcss": "8.5.18"
  }
}
