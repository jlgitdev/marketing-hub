# Optional. The UI can hold a temporary key in backend process memory instead.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6
OPENAI_IMAGE_MODEL=gpt-image-2

# Enables deterministic, network-free provider fixtures.
MARKETING_HUB_DEMO_MODE=false

# Optional deterministic pause before demo operations execute; normal default is 0.
MARKETING_HUB_DEMO_DELAY_MS=0

# Defaults to ./.marketing-hub
MARKETING_HUB_DATA_DIR=.marketing-hub

# Defaults to ./assets for context and is automatically imported in live mode.
MARKETING_HUB_CONTEXT_DIR="./assets for context"

# Downloaded AGI Summit bundle and images used by Speaker Spotlight extraction.
# Defaults to ./agi-summit-site when omitted.
AGI_SUMMIT_SITE_DIR="./agi-summit-site"
